# Общие
NODE_ENV=production
PORT=5001
LOG_LEVEL=info

# База данных
DB_HOST=localhost
DB_PORT=5432
DB_NAME=filter_monitoring
DB_USER=postgres
DB_PASSWORD=your_secure_password

# JWT
JWT_SECRET=your_super_secret_key_change_me
JWT_EXPIRES_IN=7d

# Планировщик (cron)
CRON_SCHEDULE=0 * * * *

# Email
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_TO=

# Интеграция с ТОИР
TOIR_API_URL=
TOIR_API_KEY=
TOIR_SYNC_CRON=0 2 * * *

ASU_API_URL=
ASU_API_KEY=
ASU_SYNC_CRON=0 */6 * * *