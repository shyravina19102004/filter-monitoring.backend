{
  "name": "filter-monitoring-backend",
  "version": "1.0.0",
  "description": "Backend for filter monitoring system",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "start:prod": "cross-env NODE_ENV=production node server.js",
    "dev": "nodemon server.js",
    "migrate": "npx sequelize-cli db:migrate --config src/config/database.js",
    "migrate:undo": "npx sequelize-cli db:migrate:undo --config src/config/database.js",
    "seed": "npx sequelize-cli db:seed:all --config src/config/database.js",
    "seed:undo": "npx sequelize-cli db:seed:undo --config src/config/database.js",
    "test": "cross-env NODE_ENV=test DOTENV_CONFIG_PATH=.env.test jest --runInBand --detectOpenHandles",
    "test:watch": "npm test -- --watch",
    "test:coverage": "npm test -- --coverage",
    "pretest": "node scripts/prepare-test-db.js"
  },
  "keywords": [
    "filter",
    "monitoring",
    "express",
    "sequelize"
  ],
  "author": "Your Name",
  "license": "ISC",
  "dependencies": {
    "axios": "^1.13.6",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "exceljs": "^4.4.0",
    "express": "^4.21.2",
    "express-async-errors": "^3.1.1",
    "express-rate-limit": "^8.3.1",
    "handlebars": "^4.7.8",
    "helmet": "^8.1.0",
    "joi": "^18.0.2",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.1",
    "multer": "^2.1.1",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.2",
    "pdfkit": "^0.18.0",
    "pg": "^8.20.0",
    "pg-hstore": "^2.3.4",
    "qrcode": "^1.5.4",
    "sequelize": "^6.37.8",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/pdfkit": "^0.17.5",
    "cross-env": "^10.1.0",
    "eslint-plugin-jest": "^29.15.0",
    "jest": "^30.3.0",
    "nodemon": "^3.1.14",
    "supertest": "^7.2.2"
  }
}
